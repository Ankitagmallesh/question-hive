// @ts-nocheck
import { db } from './client.ts';
import { exams, subjects, chapters } from './schema.ts';
import { eq, and } from 'drizzle-orm';

export async function getExams() {
  return await db.select().from(exams);
}

export async function getSubjects() {
  return await db.select().from(subjects);
}

export async function getChapters() {
  return await db.select().from(chapters);
}

export async function createExam(data) {
  return await db.insert(exams).values(data);
}

export async function createSubject(data) {
  return await db.insert(subjects).values(data);
}

export async function createChapter(data) {
  return await db.insert(chapters).values(data);
}

export async function updateExam(id, data) {
  return await db.update(exams).set(data).where(eq(exams.id, id));
}

export async function updateSubject(id, data) {
  return await db.update(subjects).set(data).where(eq(subjects.id, id));
}

export async function updateChapter(id, data) {
  return await db.update(chapters).set(data).where(eq(chapters.id, id));
}

export async function deleteExam(id) {
  return await db.delete(exams).where(eq(exams.id, id));
}

export async function deleteSubject(id) {
  return await db.delete(subjects).where(eq(subjects.id, id));
}

export async function deleteChapter(id) {
  return await db.delete(chapters).where(eq(chapters.id, id));
}
{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate --config=../../drizzle.config.ts",
    "migrate": "cd ../../ && drizzle-kit push --config=drizzle.config.ts",
    "seed": "node --import ./loader.mjs src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.32.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.2",
    "ts-node": "^10.9.2"
  }
}