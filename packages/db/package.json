{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate --config=../../drizzle.config.ts",
    "migrate": "drizzle-kit push --config=../../drizzle.config.ts",
    "seed": "node --loader ts-node/esm src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.32.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.2",
    "ts-node": "^10.9.2"
  }
}
